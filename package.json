{
  "name": "oauth-ai-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "OAuth for AI accounts — add 'Connect with OpenAI' / 'Connect with Claude' to any app.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "dev": "pnpm -r --parallel --filter \"./packages/*\" dev",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.cache",
    "example": "pnpm --filter oauth-ai-example-nextjs dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
