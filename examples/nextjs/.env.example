# Public base URL of this app (used to build the OAuth redirect URI).
APP_BASE_URL=http://localhost:3000

# Optional: supply your OWN registered OAuth client ids here. If omitted, the
# provider packages fall back to the vendors' first-party client ids, which is
# a Terms-of-Service gray area — see the root README.
# OAUTH_AI_OPENAI_CLIENT_ID=
# OAUTH_AI_ANTHROPIC_CLIENT_ID=

# Secret used only to sign the short-lived PKCE/state cookie in this demo.
OAUTH_AI_COOKIE_SECRET=change-me-in-production
