{
  "name": "@oauth-ai/anthropic",
  "version": "0.1.0",
  "description": "Anthropic (Sign in with Claude) provider adapter for oauth-ai.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshtomar6/oauth-ai.git",
    "directory": "packages/anthropic"
  },
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@oauth-ai/core": "workspace:^"
  },
  "devDependencies": {
    "@oauth-ai/core": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
